{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "antlr4",
      "camelcase": "Antlr4",
      "title": "Antlr4",
      "scope": "source.antlr4",
      "file-types": [
        "antlr4"
      ],
      "injection-regex": "^antlr4$",
      "class-name": "TreeSitterAntlr4"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Antlr4 grammar for tree-sitter",
    "authors": [
      {
        "name": "simonvic",
        "email": "simonvic.dev@gmail.com",
        "url": "https://simonvic.it"
      }
    ],
    "links": {
      "repository": "https://github.com/simonvic/tree-sitter-antlr4",
      "funding": ""
    }
  },
  "bindings": {
    "c": false,
    "go": false,
    "java": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}